# LLM Provider (GreenNode AIP — OpenAI-compatible)
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_API_KEY=your-greennode-aip-key
LLM_MODEL=gemini-2.0-flash

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# SSH access — dùng chung 1 username/password cho tất cả server
# Agent tự đọc IP từ alert payload (alert.instance)
SSH_USERNAME=your-username
SSH_PASSWORD=your-password
SSH_PRIVATE_KEY_PATH=   # để trống nếu dùng password
BASTION_HOST=           # để trống nếu không có bastion

# Metrics
PROMETHEUS_URL=http://prometheus:9090

# Auth — mật khẩu admin mặc định (chỉ tạo lần đầu khi data/users.json chưa tồn tại)
ADMIN_DEFAULT_PASSWORD=your-secure-admin-password

# Auto-learn: URL công khai của agent để tạo link lưu knowledge 1-click qua Telegram
# Ví dụ: https://abc123.agentbase.greennode.vn
AGENT_BASE_URL=https://your-agentbase-endpoint

# CheckMK (chỉ dùng khi network_monitoring_enabled=true trong config.yaml)
CHECKMK_URL=https://your-checkmk-host/site-name
CHECKMK_USERNAME=automation
CHECKMK_AUTOMATION_SECRET=your-automation-secret

# Mock mode — set to true for local testing without real SSH/metrics
MOCK_MODE=false

# Config file path (optional, defaults to config.yaml)
# CONFIG_PATH=config.yaml
