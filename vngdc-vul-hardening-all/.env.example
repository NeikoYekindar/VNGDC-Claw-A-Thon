# ============================================================
# GreenNode AgentBase — IAM Credentials
# ============================================================
GREENNODE_CLIENT_ID=
GREENNODE_CLIENT_SECRET=
GREENNODE_AGENT_IDENTITY=

# ============================================================
# Memory (AgentBase Memory Store)
# Create with: /agentbase-memory
# ============================================================
MEMORY_ID=
MEMORY_STRATEGY_ID=default

# ============================================================
# LLM — MiniMax (OpenAI-compatible API)
# Get API key at: https://www.minimaxi.com/
# ============================================================
LLM_API_KEY=
LLM_BASE_URL=https://api.minimaxi.chat/v1
LLM_MODEL=MiniMax-Text-01

# ============================================================
# Dashboard + Agent runtime
# LOCAL_AGENT_ENABLED=true means dashboard calls the model/agent inside the same image.
# AGENT_URL is optional; set it only when you intentionally want to call a separate agent runtime.
# ============================================================
LOCAL_AGENT_ENABLED=true
ENABLE_AGENT_DAILY_SCHEDULER=true
AGENT_URL=
HARDENING_AGENT_TIMEOUT_SECONDS=360
VULN_REFRESH_INTERVAL_SECONDS=900
VULN_REFRESH_INCLUDE_ANALYSIS=false
VULN_REFRESH_SEND_REPORT=false
VULN_ENRICHMENT_ENABLED=true
VULN_ENRICHMENT_TTL_HOURS=24
VULN_ENRICHMENT_MAX_CVES=150
VULN_ENRICHMENT_OSV_MAX_CVES=30
NVD_API_KEY=

# ============================================================
# Microsoft Teams Webhook
# Create at: Teams channel → Connectors → Incoming Webhook
# ============================================================
TEAMS_WEBHOOK_URL=

# ============================================================
# Wazuh Manager
# ============================================================
WAZUH_HOST=
WAZUH_PORT=55000
WAZUH_USER=wazuh-wui
WAZUH_PASSWORD=

# Wazuh Indexer (recommended for Vulnerability Detection)
# Uses index: wazuh-states-vulnerabilities*
WAZUH_INDEXER_HOST=
WAZUH_INDEXER_PORT=9200
WAZUH_INDEXER_USER=
WAZUH_INDEXER_PASSWORD=
WAZUH_INDEXER_VERIFY_SSL=false
WAZUH_INDEXER_INDEX=wazuh-states-vulnerabilities*
WAZUH_VULN_BATCH_SIZE=500
WAZUH_VULN_MAX_ITEMS=5000

# ============================================================
# SSH — Hardening Checks
# HARDENING_SERVERS: comma-separated "user@host" or "user@host:port"
# Example: root@192.168.1.10,ubuntu@10.0.0.5:2222
# ============================================================
HARDENING_SERVERS=
SSH_KEY_PATH=       # Path to SSH private key (leave empty to use password)
SSH_PASSWORD=       # SSH password (used only if SSH_KEY_PATH not set)

# ============================================================
# Scheduler
# ============================================================
SCHEDULE_HOUR=9
SCHEDULE_MINUTE=0
TIMEZONE=Asia/Ho_Chi_Minh
