{
  "os_type": "ubuntu",
  "display_name": "Ubuntu 24.04",
  "description": "Ubuntu hardening baseline aligned with the configured package, timezone, and sensitive-file permission commands.",
  "controls": [
    {
      "id": "UBU-APT-001",
      "section": "SYSTEM UPDATES",
      "setting": "apt metadata",
      "expected": "refreshed within 7 days",
      "check": "APT package metadata should be recently refreshed after apt update.",
      "remediation": "sudo apt update"
    },
    {
      "id": "UBU-APT-002",
      "section": "SYSTEM UPDATES",
      "setting": "package upgrades",
      "expected": "0 upgradable packages",
      "check": "No package upgrades should remain immediately after apt upgrade -y.",
      "remediation": "sudo apt update && sudo apt upgrade -y"
    },
    {
      "id": "UBU-PKG-001",
      "section": "REQUIRED PACKAGES",
      "setting": "curl",
      "expected": "installed",
      "check": "curl package must be installed.",
